---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <!-- Homepage -->
    <url>
        <loc>{{ site.url }}/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>1.00</priority>
    </url>

    <!-- Main Pages -->
    <url>
        <loc>{{ site.url }}/about/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>{{ site.url }}/cv/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>{{ site.url }}/resume/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.70</priority>
    </url>

    <url>
        <loc>{{ site.url }}/projects/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>{{ site.url }}/blog/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>0.90</priority>
    </url>

    <url>
        <loc>{{ site.url }}/tools/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>{{ site.url }}/guide/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>{{ site.url }}/insights/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>{{ site.url }}/finance/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>0.75</priority>
    </url>

    <url>
        <loc>{{ site.url }}/styleguide/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.60</priority>
    </url>

    <url>
        <loc>{{ site.url }}/terms/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.30</priority>
    </url>

    <!-- Blog Posts - Only canonical URLs, no parameters -->
    {% for post in site.posts %}
    <url>
        <loc>{{ site.url }}{{ post.url }}</loc>
        <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.70</priority>
    </url>
    {% endfor %}

    <!-- Style Guide Pages -->
    <url>
        <loc>{{ site.url }}/styleguide/cppguide/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.50</priority>
    </url>

    <url>
        <loc>{{ site.url }}/styleguide/csharp-style/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.50</priority>
    </url>

    <url>
        <loc>{{ site.url }}/styleguide/javaguide/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.50</priority>
    </url>

    <url>
        <loc>{{ site.url }}/styleguide/jsguide/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.50</priority>
    </url>

    <url>
        <loc>{{ site.url }}/styleguide/pyguide/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.50</priority>
    </url>

    <url>
        <loc>{{ site.url }}/styleguide/shellguide/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.50</priority>
    </url>

    <!-- Tools Pages -->
    <url>
        <loc>{{ site.url }}/income-tax-calculator/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.70</priority>
    </url>

    <url>
        <loc>{{ site.url }}/finance/market/</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>0.75</priority>
    </url>

</urlset>
