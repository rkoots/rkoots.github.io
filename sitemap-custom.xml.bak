---
layout: null
permalink: /sitemap.xml
---

<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <!-- Homepage -->
    <url>
        <loc>https://rkoots.github.io/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>1.00</priority>
    </url>

    <!-- Main Pages -->
    <url>
        <loc>https://rkoots.github.io/about/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>https://rkoots.github.io/cv/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>https://rkoots.github.io/resume/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.70</priority>
    </url>

    <url>
        <loc>https://rkoots.github.io/projects/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>https://rkoots.github.io/terms/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.30</priority>
    </url>

    <!-- Category Pages -->
    <url>
        <loc>https://rkoots.github.io/blog/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>0.90</priority>
    </url>

    <url>
        <loc>https://rkoots.github.io/tools/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>https://rkoots.github.io/guide/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>https://rkoots.github.io/insights/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.80</priority>
    </url>

    <url>
        <loc>https://rkoots.github.io/finance/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>0.75</priority>
    </url>

    <url>
        <loc>https://rkoots.github.io/styleguide/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.60</priority>
    </url>

    <!-- Finance Sub-pages -->
    <url>
        <loc>https://rkoots.github.io/finance/market/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>0.75</priority>
    </url>

    <!-- Tools Sub-pages -->
    <url>
        <loc>https://rkoots.github.io/income-tax-calculator/</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.70</priority>
    </url>

    <!-- Style Guide Pages -->
    {% for page in site.pages %}
      {% if page.url contains '/styleguide/' and page.url != '/styleguide/' %}
    <url>
        <loc>https://rkoots.github.io{{ page.url | remove: '.html' | append: '/' }}</loc>
        <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.50</priority>
    </url>
      {% endif %}
    {% endfor %}

    <!-- Blog Posts - Only canonical URLs, no parameters -->
    {% assign all_posts = site.posts | sort: "date" | reverse %}
    {% for post in all_posts %}
    <url>
        <loc>{{ site.url }}{{ post.url }}</loc>
        <lastmod>{{ post.date | date: "%Y-%m-%d" }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.70</priority>
    </url>
    {% endfor %}

</urlset>
